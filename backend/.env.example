# ─────────────────────────────────────────────────────────────────────────────
# PRMS Backend — Environment Variables
# Copy this file to .env and fill in the values before starting the server.
# ─────────────────────────────────────────────────────────────────────────────

# Database
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://prms_user:prms_password@localhost:5432/prms_db

# Security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-string-at-least-32-characters-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Application
ENVIRONMENT=development
DEBUG=true
PROJECT_NAME=PRMS API
API_V1_STR=/api/v1

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Logging
LOG_LEVEL=INFO
